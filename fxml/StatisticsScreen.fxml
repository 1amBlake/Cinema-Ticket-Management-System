                                                  prefHeight="250.0"
                                                  styleClass="ticket-session-chart"
                                                  VBox.vgrow="ALWAYS">
                                            <xAxis>
                                                <CategoryAxis animated="false" />
                                            </xAxis>
                                            <yAxis>
                                                <NumberAxis animated="false" forceZeroInRange="false" />
                                            </yAxis>
                                        </BarChart>
                                    </children>
                                </VBox>

