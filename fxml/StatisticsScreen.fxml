                            </columnConstraints>

                            <children>
                                <VBox spacing="8.0" styleClass="stats-card-accent-green" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <Label text="T&#7893;ng v&#233; &#273;&#227; b&#225;n" styleClass="stats-card-title" />
