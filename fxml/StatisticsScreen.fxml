                                                <CategoryAxis animated="false" />
                                            </xAxis>
                                            <yAxis>
                                                <NumberAxis animated="false" forceZeroInRange="false" />
                                            </yAxis>
                                        </BarChart>
                                    </children>
                                </VBox>

