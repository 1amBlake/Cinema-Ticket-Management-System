                                        </LineChart>
                                    </children>
                                </VBox>

                                <VBox spacing="12.0" styleClass="panel-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label text="Theo phim" styleClass="panel-title" />
