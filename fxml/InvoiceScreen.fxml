            <children>
                <HBox spacing="16.0">
                    <children>
                        <VBox spacing="6.0" styleClass="summary-card-primary" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="T&#7893;ng h&#243;a &#273;&#417;n" styleClass="summary-title" />
                                <Label fx:id="totalInvoicesValueLabel" text="0" styleClass="summary-value" />
                                <Label text="To&#224;n b&#7897; h&#243;a &#273;&#417;n &#273;ang c&#243; trong danh s&#225;ch hi&#7875;n th&#7883;." styleClass="summary-note" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0" styleClass="summary-card-success" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="H&#243;a &#273;&#417;n th&#224;nh c&#244;ng" styleClass="summary-title" />
