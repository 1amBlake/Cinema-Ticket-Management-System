                                        <TableColumn fx:id="invoiceEmployeeColumn" prefWidth="180.0" text="Nh&#226;n vi&#234;n" />
                                        <TableColumn fx:id="invoicePaymentMethodColumn" prefWidth="140.0" text="Thanh to&#225;n" />
                                        <TableColumn fx:id="invoiceStatusColumn" prefWidth="145.0" text="Tr&#7841;ng th&#225;i" />
                                        <TableColumn fx:id="invoiceTimeColumn" prefWidth="170.0" text="Th&#7901;i gian" />
                                        <TableColumn fx:id="invoiceTotalColumn" prefWidth="140.0" text="T&#7893;ng ti&#7873;n" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox minWidth="430.0" prefWidth="430.0" spacing="18.0">
                            <children>
                                <VBox spacing="14.0" styleClass="detail-overview-card">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <VBox spacing="2.0">
                                                    <children>
                                                        <Label text="Chi ti&#7871;t h&#243;a &#273;&#417;n" styleClass="panel-title" />
                                                        <Label text="Th&#244;ng tin chung v&#224; t&#7893;ng h&#7907;p gi&#225; tr&#7883; c&#7911;a h&#243;a &#273;&#417;n &#273;ang ch&#7885;n." styleClass="panel-subtitle" />
                                                    </children>
                                                </VBox>

                                                <Region HBox.hgrow="ALWAYS" />

