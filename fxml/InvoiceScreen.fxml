                                            </children>
                                        </HBox>

                                        <GridPane hgap="14.0" vgap="10.0">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="38.0" />
                                                <ColumnConstraints percentWidth="62.0" />
                                            </columnConstraints>

                                            <children>
                                                <Label text="M&#227; h&#243;a &#273;&#417;n" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                <Label fx:id="detailInvoiceIdValueLabel" text="-" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                                <Label text="Nh&#226;n vi&#234;n l&#7853;p" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                                <Label fx:id="detailEmployeeValueLabel" text="-" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                                <Label text="Thanh to&#225;n" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                                <Label fx:id="detailPaymentMethodValueLabel" text="-" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                                <Label text="Th&#7901;i gian thanh to&#225;n" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                                <Label fx:id="detailPaymentTimeValueLabel" text="-" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                                <Label text="Th&#7901;i gian t&#7841;o" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                                <Label fx:id="detailCreatedAtValueLabel" text="-" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                            </children>
                                        </GridPane>

                                        <HBox spacing="12.0">
                                            <children>
                                                <VBox spacing="4.0" styleClass="amount-card-ticket" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="V&#233;" styleClass="amount-title" />
                                                        <Label fx:id="detailTicketCountValueLabel" text="0 ve" styleClass="amount-value" />
                                                        <Label fx:id="detailTicketTotalValueLabel" text="0 &#273;" styleClass="amount-note" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4.0" styleClass="amount-card-product" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="S&#7843;n ph&#7849;m" styleClass="amount-title" />
                                                        <Label fx:id="detailProductCountValueLabel" text="0 mon" styleClass="amount-value" />
                                                        <Label fx:id="detailProductTotalValueLabel" text="0 &#273;" styleClass="amount-note" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4.0" styleClass="amount-card-total" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="T&#7893;ng h&#243;a &#273;&#417;n" styleClass="amount-title" />
                                                        <Label fx:id="detailGrandTotalValueLabel" text="0 &#273;" styleClass="amount-value" />
                                                        <Label text="Gia tri thanh toan" styleClass="amount-note" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="12.0" styleClass="detail-panel">
                                    <children>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label text="V&#233; trong h&#243;a &#273;&#417;n" styleClass="panel-title" />
                                                <Label text="Danh s&#225;ch v&#233; &#273;&#227; &#273;&#432;&#7907;c g&#7845;n v&#224;o h&#243;a &#273;&#417;n." styleClass="panel-subtitle" />
                                            </children>
                                        </VBox>

                                        <TableView fx:id="ticketDetailTable" prefHeight="160.0" styleClass="detail-table">
                                            <columns>
                                                <TableColumn fx:id="ticketIdColumn" prefWidth="190.0" text="M&#227; v&#233;" />
                                                <TableColumn fx:id="ticketPriceColumn" prefWidth="190.0" text="&#272;&#417;n gi&#225;" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>

                                <VBox spacing="12.0" styleClass="detail-panel">
                                    <children>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label text="S&#7843;n ph&#7849;m trong h&#243;a &#273;&#417;n" styleClass="panel-title" />
                                                <Label text="Theo d&#245;i c&#225;c m&#243;n b&#225;n k&#232;m &#273;i c&#249;ng h&#243;a &#273;&#417;n." styleClass="panel-subtitle" />
                                            </children>
                                        </VBox>

                                        <TableView fx:id="productDetailTable" prefHeight="190.0" styleClass="detail-table">
                                            <columns>
