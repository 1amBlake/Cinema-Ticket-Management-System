                            </children>
                        </VBox>

                        <VBox spacing="6.0" styleClass="summary-card-warning" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="H&#243;a &#273;&#417;n h&#244;m nay" styleClass="summary-title" />
                                <Label fx:id="todayInvoicesValueLabel" text="0" styleClass="summary-value" />
                                <Label text="S&#7889; h&#243;a &#273;&#417;n ph&#225;t sinh trong ng&#224;y hi&#7879;n t&#7841;i." styleClass="summary-note" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0" styleClass="summary-card-dark" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="T&#7893;ng gi&#225; tr&#7883; h&#243;a &#273;&#417;n" styleClass="summary-title" />
                                <Label fx:id="totalAmountValueLabel" text="0 &#273;" styleClass="summary-value" />
                                <Label text="Bao g&#7891;m to&#224;n b&#7897; v&#233; v&#224; s&#7843;n ph&#7849;m c&#7911;a danh s&#225;ch hi&#7879;n t&#7841;i." styleClass="summary-note" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="10.0" styleClass="toolbar-card">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Danh s&#225;ch h&#243;a &#273;&#417;n" styleClass="panel-title" />
                                        <Label text="T&#236;m theo m&#227; h&#243;a &#273;&#417;n &#273;&#7875; l&#7885;c nhanh v&#224; xem chi ti&#7871;t." styleClass="panel-subtitle" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <TextField fx:id="invoiceSearchField"
                                           onAction="#handleSearch"
                                           prefWidth="220.0"
                                           promptText="Nhap ma hoa don, vi du 12 hoac HD-0012"
                                           styleClass="search-field" />

                                <Button mnemonicParsing="false"
                                        onAction="#handleSearch"
                                        styleClass="primary-action-button"
                                        text="T&#236;m" />

                                <Button mnemonicParsing="false"
                                        onAction="#handleResetSearch"
                                        styleClass="secondary-action-button"
                                        text="B&#7887; l&#7885;c" />

                                <Button mnemonicParsing="false"
                                        onAction="#handleRefreshInvoices"
                                        styleClass="ghost-action-button"
                                        text="T&#7843;i l&#7841;i" />
                            </children>
                        </HBox>

                        <Label fx:id="searchMessageLabel"
                               text="Danh s&#225;ch h&#243;a &#273;&#417;n s&#7861; hi&#7875;n th&#7883; t&#7841;i &#273;&#226;y."
