            vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cinema.controller.InvoiceScreenController">
    <content>
        <VBox fx:id="invoiceRoot" spacing="18.0" styleClass="invoice-root">
            <padding>
