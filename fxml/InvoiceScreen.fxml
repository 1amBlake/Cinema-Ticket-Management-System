                                                <TableColumn fx:id="productQuantityColumn" prefWidth="85.0" text="SL" />
                                                <TableColumn fx:id="productUnitPriceColumn" prefWidth="110.0" text="&#272;&#417;n gi&#225;" />
                                                <TableColumn fx:id="productTotalColumn" prefWidth="110.0" text="Th&#224;nh ti&#7873;n" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
