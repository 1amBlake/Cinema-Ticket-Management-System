<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1200.0" prefHeight="750.0"
            minWidth="1000.0" minHeight="650.0"
            styleClass="dashboard-root"
            stylesheets="@../css/dashboard-screen.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cinema.controller.DashboardScreenController">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox fx:id="sidebar" prefWidth="250.0" minWidth="250.0" maxWidth="250.0"
              spacing="14.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="22.0" right="18.0" bottom="18.0" left="18.0" />
            </padding>

            <children>
                <VBox fx:id="sidebarHeader" alignment="CENTER" spacing="10.0" styleClass="sidebar-header">
                    <children>
                        <StackPane styleClass="logo-wrapper">
                            <children>
                                <ImageView fx:id="logoImage" fitWidth="76.0" fitHeight="76.0"
                                           pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../images/logo.png" />
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>

                        <VBox alignment="CENTER" spacing="2.0">
                            <children>
                                <Label fx:id="appNameLabel" text="CINEMA" styleClass="brand-title" />
                                <Label fx:id="appSubtitleLabel" text="Ticket Management" styleClass="brand-subtitle" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <Separator styleClass="sidebar-separator" />

                <VBox fx:id="menuBox" spacing="7.0" styleClass="menu-box">
				    <children>
				        <Button fx:id="overviewButton" text="  Tổng quan" maxWidth="Infinity"
				                mnemonicParsing="false" styleClass="sidebar-button" onAction="#handleOverview">
				            <graphic>
				                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/home.png" /></image></ImageView></children></StackPane>
				            </graphic>
				        </Button>
				
				        <Button fx:id="ticketSaleButton" text="  Bán vé" maxWidth="Infinity"
				                mnemonicParsing="false" styleClass="sidebar-button" onAction="#handleTicketSale">
				            <graphic>
				                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/ticket.png" /></image></ImageView></children></StackPane>
				            </graphic>
				        </Button>
				
				        <Button fx:id="invoiceButton" text="  Hóa đơn" maxWidth="Infinity"
				                mnemonicParsing="false" styleClass="sidebar-button" onAction="#handleInvoice">
				            <graphic>
				                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/invoice.png" /></image></ImageView></children></StackPane>
				            </graphic>
				        </Button>
				
				        <Button fx:id="movieButton" text="  Phim" maxWidth="Infinity"
				                mnemonicParsing="false" styleClass="sidebar-button" onAction="#handleMovieManagement">
				            <graphic>
				                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/movie.png" /></image></ImageView></children></StackPane>
				            </graphic>
				        </Button>
				
				        <Button fx:id="movieSessionButton" text="  Suất chiếu" maxWidth="Infinity"
				                mnemonicParsing="false" styleClass="sidebar-button" onAction="#handleMovieSession">
				            <graphic>
				                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/session.png" /></image></ImageView></children></StackPane>
				            </graphic>
				        </Button>
				
				        <Button fx:id="theaterButton" text="  Phòng &amp; ghế" maxWidth="Infinity"
				                mnemonicParsing="false" styleClass="sidebar-button" onAction="#handleTheaterManagement">
				            <graphic>
				                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/room-seat.png" /></image></ImageView></children></StackPane>
				            </graphic>
				        </Button>
				
				        <Button fx:id="productButton" text="  Sản phẩm" maxWidth="Infinity"
				                mnemonicParsing="false" styleClass="sidebar-button" onAction="#handleProductManagement">
				            <graphic>
				                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/product.png" /></image></ImageView></children></StackPane>
				            </graphic>
				        </Button>
				
				        <Button fx:id="employeeButton" text="  Nhân viên" maxWidth="Infinity"
				                mnemonicParsing="false" styleClass="sidebar-button" onAction="#handleEmployeeManagement">
				            <graphic>
				                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/employee.png" /></image></ImageView></children></StackPane>
				            </graphic>
				        </Button>
				
				        <Button fx:id="statisticsButton" text="  Thống kê" maxWidth="Infinity"
				                mnemonicParsing="false" styleClass="sidebar-button" onAction="#handleStatistics">
				            <graphic>
				                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/statistics.png" /></image></ImageView></children></StackPane>
				            </graphic>
				        </Button>
				    </children>
				</VBox>

                <Region fx:id="sidebarSpacer" VBox.vgrow="ALWAYS" />

                <VBox fx:id="sidebarFooter" spacing="10.0" styleClass="sidebar-footer">
                    <children>
                        <VBox spacing="3.0" styleClass="user-card">
                            <children>
                                <Label fx:id="helloLabel" text="Đang đăng nhập" styleClass="user-muted-label" />
                                <Label fx:id="employeeNameLabel" text="Nhân viên" styleClass="user-name-label" />
                            </children>
                        </VBox>

                        <Button fx:id="accountButton" text="  Tài khoản" maxWidth="Infinity"
                                mnemonicParsing="false" styleClass="sidebar-secondary-button">
                            <graphic>
                                <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper"><children><ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon"><image><Image url="@../images/icons/account.png" /></image></ImageView></children></StackPane>
                            </graphic>
                        </Button>

                        <Button fx:id="logoutButton" text="  Đăng xuất" maxWidth="Infinity"
						        mnemonicParsing="false" styleClass="logout-button" onAction="#handleLogout">
						    <graphic>
						        <StackPane alignment="CENTER" minWidth="24.0" prefWidth="24.0" maxWidth="24.0" styleClass="sidebar-icon-wrapper">
						            <children>
						                <ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" pickOnBounds="true" styleClass="sidebar-menu-icon">
						                    <image>
						                        <Image url="@../images/icons/logout.png" />
						                    </image>
						                </ImageView>
						            </children>
						        </StackPane>
						    </graphic>
						</Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <!-- MAIN AREA -->
    <center>
        <BorderPane fx:id="mainArea" styleClass="main-area" BorderPane.alignment="CENTER">
            <top>
                <HBox fx:id="topBar" alignment="CENTER_LEFT" spacing="14.0"
                      styleClass="top-bar" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="16.0" right="24.0" bottom="16.0" left="24.0" />
                    </padding>

                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Label fx:id="pageTitleLabel" text="Dashboard" styleClass="page-title" />
                                <Label fx:id="pageDescriptionLabel"
                                       text="Chọn một chức năng ở thanh bên trái để bắt đầu"
                                       styleClass="page-description" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox fx:id="topUserBox" alignment="CENTER" spacing="10.0" styleClass="top-user-box">
                            <children>
                                <StackPane styleClass="top-avatar">
                                    <children>
                                        <Label fx:id="topAvatarLabel" text="NV" styleClass="top-avatar-text" />
                                    </children>
                                </StackPane>

                                <VBox alignment="CENTER_LEFT" spacing="2.0">
                                    <children>
                                        <Label fx:id="topPermissionTitleLabel" text="Quyền" styleClass="top-user-name" />
                                        <Label fx:id="topPermissionValueLabel" text="Nhân viên" styleClass="top-user-role" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </top>

            <center>
                <StackPane fx:id="contentArea" styleClass="content-area" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
                    </padding>

                    <children>
                        <VBox fx:id="welcomeBox" alignment="CENTER" spacing="14.0" styleClass="welcome-card">
                            <children>
                                <Label text="Chào mừng đến với Cinema Ticket Management"
                                       styleClass="welcome-title" />
                                <Label text="Chọn một chức năng ở thanh bên trái để bắt đầu."
                                       styleClass="welcome-subtitle" />

                                <HBox alignment="CENTER" spacing="12.0">
								    <children>
								        <Button fx:id="quickSaleButton" text="Bán vé ngay"
								                mnemonicParsing="false"
								                styleClass="primary-button" 
								                onAction="#handleTicketSale" />
								                
								        <Button fx:id="quickInvoiceButton" text="Xem hóa đơn"
								                mnemonicParsing="false"
								                styleClass="outline-button" 
								                onAction="#handleInvoice" />
								    </children>
								</HBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>

<!--

fx:id quan trọng:
contentArea, pageTitleLabel, pageDescriptionLabel,
overviewButton, ticketSaleButton, invoiceButton, movieButton, movieSessionButton,
theaterButton, productButton, employeeButton, statisticsButton,
accountButton, logoutButton, quickSaleButton, quickInvoiceButton,
employeeNameLabel, topAvatarLabel, topPermissionValueLabel
-->
