<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cinema.controller.DashboardController"
            stylesheets="@../css/dashboard.css">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="20">
            <Label text="🎬 Cinema Ticket Management" styleClass="app-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Xin chào, Minh Huy" styleClass="user-label"/>
            <Button text="Đăng xuất" styleClass="logout-button"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="side-bar" spacing="8">
            <Button text="🏠 Tổng quan" styleClass="menu-button"/>
            <Button text="🎟 Bán vé" styleClass="menu-button"/>
            <Button text="🧾 Hóa đơn" styleClass="menu-button"/>
            <Button text="🎬 Phim" styleClass="menu-button"/>
            <Button text="🕒 Suất chiếu" styleClass="menu-button"/>
            <Button text="🏢 Phòng &amp; ghế" styleClass="menu-button"/>
            <Button text="🍿 Sản phẩm" styleClass="menu-button"/>
            <Button text="👤 Nhân viên" styleClass="menu-button"/>
            <Button text="📊 Thống kê" styleClass="menu-button"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <VBox styleClass="content-box" spacing="20">

                <Label text="Tổng quan hệ thống" styleClass="page-title"/>

                <!-- STAT CARDS -->
                <HBox spacing="16">
                    <VBox styleClass="stat-card">
                        <Label text="Vé bán hôm nay" styleClass="card-title"/>
                        <Label text="128" styleClass="card-number"/>
                    </VBox>

                    <VBox styleClass="stat-card">
                        <Label text="Doanh thu hôm nay" styleClass="card-title"/>
                        <Label text="12,500,000đ" styleClass="card-number"/>
                    </VBox>

                    <VBox styleClass="stat-card">
                        <Label text="Hóa đơn hôm nay" styleClass="card-title"/>
                        <Label text="46" styleClass="card-number"/>
                    </VBox>

                    <VBox styleClass="stat-card">
                        <Label text="Suất chiếu hôm nay" styleClass="card-title"/>
                        <Label text="18" styleClass="card-number"/>
                    </VBox>
                </HBox>

                <!-- TODAY SESSIONS -->
                <VBox styleClass="panel-box" spacing="10">
                    <Label text="Suất chiếu hôm nay" styleClass="section-title"/>

                    <TableView prefHeight="220">
                        <columns>
                            <TableColumn text="Giờ chiếu" prefWidth="120"/>
                            <TableColumn text="Phim" prefWidth="250"/>
                            <TableColumn text="Phòng" prefWidth="120"/>
                            <TableColumn text="Trạng thái" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- LOWER PANELS -->
                <HBox spacing="16">
                    <VBox styleClass="panel-box" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="Phim đang chiếu" styleClass="section-title"/>
                        <ListView prefHeight="180"/>
                    </VBox>

                    <VBox styleClass="panel-box" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="Sản phẩm bán chạy" styleClass="section-title"/>
                        <ListView prefHeight="180"/>
                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>