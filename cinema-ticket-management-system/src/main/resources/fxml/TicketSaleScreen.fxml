<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="ticketSaleRoot" spacing="20" styleClass="sale-root"
      stylesheets="@../css/ticket-sale-screen.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cinema.controller.TicketSaleScreenController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- STEP INDICATOR -->
    <HBox alignment="CENTER" spacing="15" styleClass="step-container">
        <children>
            <VBox fx:id="step1Indicator" styleClass="step-item step-active" alignment="CENTER">
                <Label text="1" styleClass="step-number"/>
                <Label text="Chọn Phim" styleClass="step-text"/>
            </VBox>

            <Region styleClass="step-line"/>

            <VBox fx:id="step2Indicator" styleClass="step-item" alignment="CENTER">
                <Label text="2" styleClass="step-number"/>
                <Label text="Suất Chiếu" styleClass="step-text"/>
            </VBox>

            <Region styleClass="step-line"/>

            <VBox fx:id="step3Indicator" styleClass="step-item" alignment="CENTER">
                <Label text="3" styleClass="step-number"/>
                <Label text="Thanh Toán" styleClass="step-text"/>
            </VBox>
        </children>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">

        <!-- STEP 1 -->
        <VBox fx:id="step1Pane" spacing="15" styleClass="wizard-pane">
            <children>
                <Label text="Phim đang chiếu" styleClass="section-title"/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="movieFlowPane" hgap="20" vgap="25"/>
                    </content>
                </ScrollPane>

                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="btnNextStep1"
                            text="Tiếp theo →"
                            onAction="#handleNextToStep2"
                            disable="true"
                            styleClass="next-button"/>
                </HBox>
            </children>
        </VBox>

        <!-- STEP 2 -->
        <VBox fx:id="step2Pane" spacing="15" styleClass="wizard-pane" visible="false">
            <children>
                <Label text="Chọn suất chiếu" styleClass="section-title"/>

                <HBox spacing="10">
                    <ComboBox fx:id="theaterFilter" promptText="Rạp"/>
                    <DatePicker fx:id="dateFilter"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="sessionFlowPane" hgap="15" vgap="15"/>
                    </content>
                </ScrollPane>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="← Quay lại" onAction="#handleBackToStep1" styleClass="back-button"/>
                    <Button fx:id="btnNextStep2"
                            text="Chọn ghế →"
                            onAction="#handleNextToStep3"
                            disable="true"
                            styleClass="next-button"/>
                </HBox>
            </children>
        </VBox>

        <!-- STEP 3 -->
        <HBox fx:id="step3Pane" spacing="20" visible="false">

            <!-- LEFT -->
            <TabPane tabClosingPolicy="UNAVAILABLE" HBox.hgrow="ALWAYS">
                <tabs>

                    <!-- SEAT -->
                    <Tab text="Ghế">
                        <VBox alignment="CENTER" spacing="15">
                            <children>
                                <Label text="MÀN HÌNH"/>

                                <GridPane fx:id="seatGrid"
                                          hgap="8" vgap="8"
                                          alignment="CENTER"
                                          VBox.vgrow="ALWAYS"/>

                                <HBox spacing="20" alignment="CENTER">
                                    <Label text="Trống"/>
                                    <Label text="Đang chọn"/>
                                    <Label text="Đã bán"/>
                                </HBox>
                            </children>
                        </VBox>
                    </Tab>

                    <!-- PRODUCT -->
                    <Tab text="Bắp nước">
                        <ScrollPane fitToWidth="true">
                            <content>
                                <FlowPane fx:id="productFlowPane" hgap="20" vgap="20"/>
                            </content>
                        </ScrollPane>
                    </Tab>

                </tabs>
            </TabPane>

            <!-- RIGHT: RECEIPT -->
            <VBox prefWidth="350" styleClass="receipt-panel">

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="10" styleClass="receipt-content">

                            <Label text="HÓA ĐƠN" styleClass="receipt-header"/>

                            <GridPane>
                                <children>
                                    <Label text="Ngày:"/>
                                    <Label fx:id="lblReceiptDate" GridPane.columnIndex="1"/>

                                    <Label text="Nhân viên:" GridPane.rowIndex="1"/>
                                    <Label fx:id="lblReceiptEmployee" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                </children>
                            </GridPane>

                            <Separator/>

                            <Label fx:id="lblReceiptMovie"/>
                            <Label fx:id="lblReceiptSession"/>
                            <Label fx:id="lblReceiptSeats"/>

                            <Separator/>

                            <!-- ITEMS -->
                            <VBox fx:id="receiptItemsVBox" spacing="5"/>

                            <Separator/>

                            <HBox>
                                <Label text="Tổng"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblReceiptTotal"/>
                            </HBox>

                        </VBox>
                    </content>
                </ScrollPane>

                <!-- PAYMENT -->
                <VBox spacing="10" style="-fx-padding: 10;">
                    <ComboBox fx:id="paymentMethodBox"
                              promptText="Chọn phương thức thanh toán"/>

                    <HBox spacing="10">
                        <Button text="←" onAction="#handleBackToStep2" styleClass="back-button"/>
                        <Button fx:id="btnCheckout"
                                text="Thanh toán"
                                onAction="#handlePayment"
                                disable="true"
                                styleClass="checkout-button"/>
                    </HBox>
                </VBox>

            </VBox>

        </HBox>

    </StackPane>
</VBox>