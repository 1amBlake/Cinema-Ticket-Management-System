<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="750.0" prefWidth="1100.0" styleClass="content-area" stylesheets="@../css/theater-management-screen.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cinema.controller.TheaterManagementController">
   <children>
      <TabPane tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <tabs>
          <Tab text="Quản lý Phòng Chiếu">
            <content>
                <HBox spacing="20.0">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                    <children>
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="section-title" text="Danh sách phòng" />
                                <TableView fx:id="tableScreens" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colRoomId" text="ID" prefWidth="50" />
                                        <TableColumn fx:id="colRoomName" text="Tên Phòng" prefWidth="150" />
                                        <TableColumn fx:id="colRoomType" text="Loại Phòng" prefWidth="100" />
                                        <TableColumn fx:id="colRoomStatus" text="Trạng thái" prefWidth="120" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                        <VBox minWidth="300.0" spacing="15.0" styleClass="welcome-card">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Thông tin phòng" />
                                <TextField fx:id="txtRoomName" promptText="Tên phòng (Vd: Phòng 01)" />
                                <ComboBox fx:id="cbRoomType" maxWidth="1.7976931348623157E308" promptText="-- Loại phòng --" />
                                <ComboBox fx:id="cbRoomStatus" maxWidth="1.7976931348623157E308" promptText="-- Trạng thái --" />
                                <HBox spacing="10">
                                    <Button onAction="#handleSaveRoom" styleClass="button-primary" text="Lưu phòng" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                    <Button onAction="#handleDeleteRoom" styleClass="button-red" text="Xóa" />
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </content>
          </Tab>

          <Tab text="Thiết lập Sơ đồ Ghế">
            <content>
                <VBox spacing="15.0">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="welcome-card" style="-fx-padding: 15;">
                            <children>
                                <Label text="Chọn phòng để cấu hình:" />
                                <ComboBox fx:id="cbSelectRoomForSeats" prefWidth="200" />
                                <Separator orientation="VERTICAL" />
                                <Label text="Thêm nhanh:" />
                                <TextField fx:id="txtNumRows" prefWidth="60" promptText="Hàng" />
                                <TextField fx:id="txtNumCols" prefWidth="60" promptText="Cột" />
                                <Button onAction="#handleBatchCreateSeats" styleClass="button-secondary" text="Tạo hàng loạt" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#handleSaveSeatLayout" styleClass="button-primary" text="Lưu sơ đồ" />
                            </children>
                        </HBox>
                        
                        <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                            <content>
                                <StackPane fx:id="containerSeatMap" style="-fx-background-color: #E2E8F0; -fx-background-radius: 10;">
                                    <children>
                                        <GridPane fx:id="gridSeatEditor" alignment="CENTER" hgap="5" vgap="5">
                                            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                                        </GridPane>
                                    </children>
                                </StackPane>
                            </content>
                        </ScrollPane>
                        
                        <HBox alignment="CENTER" spacing="20">
                            <children>
                                <HBox spacing="5" alignment="CENTER"><StackPane styleClass="seat-demo, seat-normal"/><Label text="Ghế Thường" /></HBox>
                                <HBox spacing="5" alignment="CENTER"><StackPane styleClass="seat-demo, seat-vip"/><Label text="Ghế VIP" /></HBox>
                                <HBox spacing="5" alignment="CENTER"><StackPane styleClass="seat-demo, seat-double"/><Label text="Ghế Đôi" /></HBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
          </Tab>
        </tabs>
      </TabPane>
   </children>
</AnchorPane>