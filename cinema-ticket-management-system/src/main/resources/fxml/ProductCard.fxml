<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" styleClass="panel-card" 
      stylesheets="@../css/overview-screen.css, @../css/dashboard-screen.css" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.cinema.controller.ProductCardController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>
    <children>
        <ImageView fx:id="productImageView" fitHeight="130.0" fitWidth="130.0" pickOnBounds="true" preserveRatio="true" />
        
        <VBox alignment="CENTER" spacing="4.0">
            <children>
                <Label fx:id="productNameLabel" styleClass="panel-title" text="Tên Sản Phẩm" textAlignment="CENTER" wrapText="true" />
                <Label fx:id="priceLabel" style="-fx-text-fill: #E50914; -fx-font-size: 16px; -fx-font-weight: 800;" text="0 đ" />
                <Label fx:id="statusLabel" styleClass="panel-subtitle" text="Tồn kho: 0" />
            </children>
        </VBox>
        
        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Button fx:id="editButton" mnemonicParsing="false" styleClass="outline-button" text="Sửa" />
                <Button fx:id="deleteButton" mnemonicParsing="false" styleClass="primary-button" text="Xóa" />
            </children>
        </HBox>
    </children>
</VBox>