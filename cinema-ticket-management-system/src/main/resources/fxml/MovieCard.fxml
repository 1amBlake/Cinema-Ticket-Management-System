<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- 1. Đổi Controller về MovieCardController -->
<VBox alignment="CENTER" spacing="12.0" styleClass="panel-card" 
      stylesheets="@../css/overview-screen.css, @../css/dashboard-screen.css" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.cinema.controller.MovieCardController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>
    <children>
        <!-- 2. Đổi fx:id từ productImageView thành movieImageView -->
        <ImageView fx:id="movieImageView" fitHeight="130.0" fitWidth="130.0" pickOnBounds="true" preserveRatio="true" />
        
        <VBox alignment="CENTER" spacing="4.0">
            <children>
                <!-- Các ID này đã đúng với MovieCardController -->
                <Label fx:id="movieNameLabel" styleClass="panel-title" text="Tên Phim" textAlignment="CENTER" wrapText="true" />
                <Label fx:id="releaseDateLabel" style="-fx-text-fill: #E50914; -fx-font-size: 16px; -fx-font-weight: 800;" text="Ngày Chiếu" />
                <Label fx:id="statusLabel" styleClass="panel-subtitle" text="Sắp Chiếu" />
            </children>
        </VBox>
        
        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Button fx:id="editButton" mnemonicParsing="false" styleClass="outline-button" text="Sửa" />
                <Button fx:id="deleteButton" mnemonicParsing="false" styleClass="primary-button" text="Xóa" />
            </children>
        </HBox>
    </children>
</VBox>