<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane styleClass="overview-root" stylesheets="@../css/overview-screen.css, @../css/dashboard-screen.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cinema.controller.EmployeeManagementScreenController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
            </padding>
            <children>
                <TextField fx:id="searchField" prefWidth="300.0" promptText="Tìm kiếm nhân viên (Enter)..." styleClass="global-search" />
                <ComboBox fx:id="categoryComboBox" prefWidth="180.0" promptText="Tất cả danh mục" styleClass="global-search" />
                <Region HBox.hgrow="ALWAYS" />
                
                <Button fx:id="addEmployeeButton" mnemonicParsing="false" styleClass="primary-button" text="+ Thêm nhân viên" />
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                
                <FlowPane fx:id="employeeFlowPane" hgap="24.0" vgap="24.0">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="8.0" />
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>