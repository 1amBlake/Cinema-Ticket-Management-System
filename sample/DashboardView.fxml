<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="dashboard-root" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cinema.controller.DashboardController">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="side-bar">

            <!-- LOGO AREA -->
            <VBox alignment="CENTER" spacing="6" styleClass="logo-box">
            <ImageView fitHeight="90.0" fitWidth="92.0" pickOnBounds="true" preserveRatio="true" />
                <Label styleClass="logo-subtitle" text="Nhóm 1" />
            </VBox>

            <!-- MENU AREA -->
            <VBox spacing="8" styleClass="menu-box" VBox.vgrow="ALWAYS">
                <Button onAction="#showOverviewScreen" styleClass="menu-button" text="🏠  Tổng quan" />

                <Button onAction="#showTicketSaleScreen" styleClass="menu-button" text="🎟  Bán vé" />

                <Button styleClass="menu-button" text="🧾  Hóa đơn" />

                <Button styleClass="menu-button" text="🎬  Phim" />

                <Button styleClass="menu-button" text="🕒  Suất chiếu" />

                <Button styleClass="menu-button" text="🏢  Phòng &amp; ghế" />

                <Button styleClass="menu-button" text="🍿  Sản phẩm" />

                <Button styleClass="menu-button" text="👤  Nhân viên" />

                <Button styleClass="menu-button" text="📊  Thống kê" />
            </VBox>

            <!-- USER AREA -->
            <VBox spacing="8" styleClass="user-box">
                <Label styleClass="user-name" text="Xin chào, Minh Huy!" />

                <Button styleClass="user-menu-button" text="👤  Tài khoản" />

                <Button styleClass="user-menu-button" text="⚙  Cài đặt" />

                <Button onAction="#logout" styleClass="exit-button" text="🚪  Thoát chương trình" />
            </VBox>

        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane">

            <!-- OVERVIEW SCREEN -->
            <ScrollPane fx:id="overviewContent" fitToHeight="true" fitToWidth="true" styleClass="main-scroll">

                <VBox spacing="20" styleClass="content-box">

                    <Label styleClass="page-title" text="Tổng quan hệ thống" />

                    <!-- STAT CARDS -->
                    <HBox spacing="16">
                        <VBox styleClass="stat-card">
                            <Label styleClass="card-title" text="Vé bán hôm nay" />
                            <Label styleClass="card-number" text="128" />
                        </VBox>

                        <VBox styleClass="stat-card">
                            <Label styleClass="card-title" text="Doanh thu hôm nay" />
                            <Label styleClass="card-number" text="12,500,000đ" />
                        </VBox>

                        <VBox styleClass="stat-card">
                            <Label styleClass="card-title" text="Hóa đơn hôm nay" />
                            <Label styleClass="card-number" text="46" />
                        </VBox>

                        <VBox styleClass="stat-card">
                            <Label styleClass="card-title" text="Suất chiếu hôm nay" />
                            <Label styleClass="card-number" text="18" />
                        </VBox>
                    </HBox>

                    <!-- TODAY SESSIONS -->
                    <VBox spacing="10" styleClass="panel-box" VBox.vgrow="ALWAYS">
                        <Label styleClass="section-title" text="Suất chiếu hôm nay" />

                        <TableView prefHeight="260" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn prefWidth="120" text="Giờ chiếu" />
                                <TableColumn prefWidth="250" text="Phim" />
                                <TableColumn prefWidth="120" text="Phòng" />
                                <TableColumn prefWidth="150" text="Trạng thái" />
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- LOWER PANELS -->
                    <HBox spacing="16">
                        <VBox spacing="10" styleClass="panel-box" HBox.hgrow="ALWAYS">
                            <Label styleClass="section-title" text="Phim đang chiếu" />
                            <ListView prefHeight="180" />
                        </VBox>

                        <VBox spacing="10" styleClass="panel-box" HBox.hgrow="ALWAYS">
                            <Label styleClass="section-title" text="Sản phẩm bán chạy" />
                            <ListView prefHeight="180" />
                        </VBox>
                    </HBox>

                </VBox>
            </ScrollPane>

        </StackPane>
    </center>

</BorderPane>
